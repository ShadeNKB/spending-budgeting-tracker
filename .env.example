# ─── Cross-device sync (optional) ───────────────────────────────────────────
#
# Leave blank to run in local-only mode (default).
# To enable sync:
#   1. Create a free project at https://supabase.com/dashboard
#   2. Run supabase/migrations/001_sync.sql in the SQL Editor
#   3. Copy Project URL and anon public key from Project Settings → API
#   4. Paste below and add the same vars to Vercel environment settings
#
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Demo mode ───────────────────────────────────────────────────────────────
# Set to "true" to seed sample Singapore expenses on first visit.
VITE_DEMO_MODE=
